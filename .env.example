ENVIRONMENT=development
LOG_LEVEL=INFO
AUTH_DISABLED=true
JWT_SECRET=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_DSN=postgresql://voice_agent:voice_agent@postgres:5432/voice_agent
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=customer_support_kb

# Docker Desktop: host.docker.internal reaches the host Ollama process.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen3:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_KEEP_ALIVE=10m

STT_MODEL=small.en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
PARTIAL_STT_ENABLED=true
PARTIAL_STT_INTERVAL_MS=1200

TTS_MODEL_PATH=/models/kokoro-v1.0.onnx
TTS_VOICES_PATH=/models/voices-v1.0.bin
TTS_VOICE=af_sarah
TTS_LANGUAGE=en-us
TTS_SPEED=1.0

AUDIO_SAMPLE_RATE=16000
VAD_THRESHOLD=0.55
MIN_SILENCE_MS=650
SPEECH_PAD_MS=160
MIN_UTTERANCE_MS=300
MAX_UTTERANCE_SECONDS=30
MAX_SESSION_MINUTES=30
MAX_CONCURRENT_SESSIONS=50

RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.25
MAX_HISTORY_MESSAGES=12
